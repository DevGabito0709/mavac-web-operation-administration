<aside class="sidebar">

    <h2><%= sidebarTitle %></h2>

    <div class="menu">

        <% if (buttons && buttons.length) { %>

            <% buttons.forEach(function(btn) { %>

                <% 
                    const esAdminBtn = btn.id === "btnAdministracion";
                    const esAdmin = auth && auth.rol === "admin";
                %>

                <% if (!esAdminBtn || esAdmin) { %>

                    <button id="<%= btn.id %>">
                        <%= btn.label %>
                    </button>

                <% } %>

            <% }); %>

        <% } %>

    </div>

</aside>